{
    "MSSQLServerSQLConnection": {
        "MSSQLServerSQLConnectionStrings": ""
    },
    "Cors": {
        "Origins": [
            "http://localhost:3000",
            "http://localhost:8080",
            "https://erudio.com.br"
        ]
    },
    "Email": {
        "Subject": "Default Subject",
        "Message": "This is default message from the API",
        "Host": "smtp.gmail.com",
        "Port": 587,
        "Username": "${EMAIL_USERNAME}",
        "Password": "${EMAIL_PASSWORD}",
        "Properties": {
            "SmtpAuth": "true",
            "StartTlsEnable": "true",
            "StartTlsRequired": "true"
        },
        "Ssl": true
    },

    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "System": "Warning",
                "RestWithAspNet10": "Debug"
            }
        },
        "WriteTo": [
            {"Name": "Console"}
        ]
    },
    
    "AllowedHosts": "*"
}
